{
  "name": "coffee-admin-backend",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS + MongoDB backend for the coffee admin dashboard and storefront flows.",
  "license": "UNLICENSED",
  "scripts": {
    "clean": "rimraf dist",
    "build": "nest build",
    "build:clean": "npm run clean && nest build",
    "start:dev": "npm run build:clean && nest start --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"@src/**/*.ts\""
  },
  "dependencies": {
    "@nestjs/common": "^10.4.2",
    "@nestjs/config": "^3.2.3",
    "@nestjs/core": "^10.4.2",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.0.6",
    "@nestjs/mongoose": "^10.1.0",
    "@nestjs/platform-express": "^10.4.2",
    "@nestjs/serve-static": "^4.0.2",
    "@nestjs/swagger": "^7.4.2",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "luxon": "^3.7.2",
    "mongoose": "^8.6.3",
    "multer": "^1.4.5-lts.1",
    "node-rsa": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "serve-static": "^1.15.0",
    "swagger-ui-express": "^5.0.1",
    "ua-parser-js": "^2.0.9",
    "ulidx": "^2.4.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.3",
    "@nestjs/testing": "^10.4.2",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.1",
    "eslint": "^9.12.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.3.3",
    "rimraf": "^6.1.3",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
